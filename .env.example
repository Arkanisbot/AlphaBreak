# Securities Prediction Model - Environment Configuration
# ========================================================
# Copy this file to .env and fill in your values.
# For AWS/EC2 deployment, you can also copy .env.aws and modify as needed.

# ═══════════════════════════════════════════════════════════════════
# DATABASE CONNECTION
# ═══════════════════════════════════════════════════════════════════
# Three sets of variable names are used across the codebase.
# Set all three for full compatibility, or just the ones you need.

# Primary (used by: database.py, populate_database.py, populate_historical_data.py, polygon_data_fetcher.py)
TIMESERIES_DB_HOST=localhost
TIMESERIES_DB_PORT=5432
TIMESERIES_DB_NAME=trading_data
TIMESERIES_DB_USER=trading
TIMESERIES_DB_PASSWORD=your-secure-password-here
TIMESERIES_DB_SSLMODE=prefer

# Secondary (used by: sec_13f_fetcher.py, cboe_options_fetcher.py, finra_darkpool_fetcher.py,
#            darkpool_options_analysis.py, f13_archive_analysis.py, options_pricing.py, populate_market_indices.py)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_data
POSTGRES_USER=trading
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_SSLMODE=prefer

# Tertiary (used by: detect_trend_breaks.py, meta_learning_model.py)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_data
DB_USER=trading
DB_PASSWORD=your-secure-password-here
DB_SSLMODE=prefer

# ═══════════════════════════════════════════════════════════════════
# EXTERNAL API KEYS
# ═══════════════════════════════════════════════════════════════════

# Polygon.io - Market data API (https://polygon.io)
# Free tier: 5 API calls/minute, delayed data
# Optional but recommended for intraday data
POLYGON_API_KEY=

# FINRA - Dark pool/OTC data (https://developer.finra.org)
# Default credentials provided, but you can register your own
FINRA_CLIENT_ID=efb640a8695c43589222
FINRA_CLIENT_SECRET=ZZ&1@b%^QvbuaBWPD^#5

# ═══════════════════════════════════════════════════════════════════
# FLASK API CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Flask environment: development, production, testing
FLASK_ENV=development

# Secret key for session signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=dev-secret-key-change-in-production

# Server port
PORT=5000

# Path to trained models directory
MODEL_DIR=models

# API key authentication (set to true in production)
API_KEY_REQUIRED=false
API_KEYS=

# CORS allowed origins (comma-separated, or * for all)
CORS_ORIGINS=*

# Redis connection (for rate limiting and caching)
REDIS_URL=redis://localhost:6379/0
RATELIMIT_STORAGE_URL=redis://localhost:6379/1

# ═══════════════════════════════════════════════════════════════════
# GUNICORN CONFIGURATION (Production only)
# ═══════════════════════════════════════════════════════════════════

GUNICORN_BIND=0.0.0.0:5000
GUNICORN_WORKERS=2
GUNICORN_LOG_LEVEL=info
